@model IEnumerable<MyWebProject.Models.Product>

@if (!Model.Any())
{
    <div class="alert alert-light text-center border-0 shadow-sm rounded-4">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        <span data-ar="لا توجد منتجات متاحة حالياً." data-en="No products available.">لا توجد منتجات متاحة حالياً.</span>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card-soft p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="mb-1 fw-semibold">@item.Name</h5>
                        <span class="badge-soft">@item.Price.ToString("N2") <span data-ar="ريال" data-en="SAR">ريال</span></span>
                    </div>
                    <p class="text-muted small mt-2">@(item.Description ?? "لا يوجد وصف")</p>
                    <p class="text-muted mt-1 mb-3"><i class="bi bi-calendar3"></i> @item.CreatedAt.ToString("yyyy/MM/dd")</p>
                    <p class="text-muted small mb-3">
                        <i class="bi bi-shop"></i> <strong data-ar="البائع:" data-en="Seller:">البائع:</strong> 
                        <span>@(item.User?.FullName ?? item.User?.UserName ?? "غير معروف")</span>
                    </p>
                    <button class="btn btn-sm btn-soft-primary w-100 rounded-pill add-to-cart-btn" data-product-id="@item.Id">
                        <i class="bi bi-cart-plus"></i> <span data-ar="أضف للسلة" data-en="Add to Cart">أضف للسلة</span>
                    </button>
                </div>
            </div>
        }
    </div>
}

<script>
    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
            const productId = this.getAttribute('data-product-id');
            const lang = localStorage.getItem('language') || 'ar';
            try {
                const response = await fetch('@Url.Action("AddToCart", "CustomerProducts")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `productId=${productId}&quantity=1`
                });
                const result = await response.json();
                if (result.success) {
                    // تحديث العداد
                    const badge = document.getElementById('cart-badge');
                    if (badge) {
                        if (result.cartCount > 0) {
                            badge.textContent = result.cartCount;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                    // Toast
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: result.message,
                        showConfirmButton: false,
                        timer: 1500,
                        timerProgressBar: true
                    });
                } else {
                    Swal.fire({ icon: 'error', title: lang === 'ar' ? 'خطأ' : 'Error', text: result.message });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: lang === 'ar' ? 'خطأ في الاتصال' : 'Connection error', text: error.message });
            }
        });
    });
</script>