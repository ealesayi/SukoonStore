@model IEnumerable<MyWebProject.Models.Product>
@{
    ViewData["Title"] = "المتجر";
}
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="h4"><i class="bi bi-shop"></i> <span data-ar="المتجر" data-en="Shop">المتجر</span></h2>
</div>

<div class="mb-4">
    <div class="input-group shadow-sm rounded-pill overflow-hidden" style="max-width: 350px;">
        <input type="text" id="searchInput" class="form-control border-0 bg-white" placeholder="ابحث باسم المنتج..." autocomplete="off" />
        <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-search"></i></span>
    </div>
</div>

<div id="productsContainer">
    @await Html.PartialAsync("_ProductCards", Model)
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const productsContainer = document.getElementById('productsContainer');
        let debounceTimer;
        searchInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            const query = this.value;
            debounceTimer = setTimeout(() => {
                fetch(`@Url.Action("SearchProducts", "CustomerProducts")?searchString=${encodeURIComponent(query)}`)
                    .then(response => response.text())
                    .then(html => {
                        productsContainer.innerHTML = html;
                        // إعادة ربط أحداث الأزرار بعد تحميل المحتوى الجديد
                        document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
                            btn.addEventListener('click', async function() {
                                // نفس الكود الموجود في _ProductCards
                                const productId = this.getAttribute('data-product-id');
                                const lang = localStorage.getItem('language') || 'ar';
                                try {
                                    const response = await fetch('@Url.Action("AddToCart", "CustomerProducts")', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                        body: `productId=${productId}&quantity=1`
                                    });
                                    const result = await response.json();
                                    if (result.success) {
                                        const badge = document.getElementById('cart-badge');
                                        if (badge) {
                                            if (result.cartCount > 0) {
                                                badge.textContent = result.cartCount;
                                                badge.style.display = 'inline-block';
                                            } else {
                                                badge.style.display = 'none';
                                            }
                                        }
                                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: result.message, showConfirmButton: false, timer: 1500 });
                                    } else {
                                        Swal.fire({ icon: 'error', title: lang === 'ar' ? 'خطأ' : 'Error', text: result.message });
                                    }
                                } catch (error) {
                                    Swal.fire({ icon: 'error', title: lang === 'ar' ? 'خطأ في الاتصال' : 'Connection error', text: error.message });
                                }
                            });
                        });
                    })
                    .catch(error => console.error(error));
            }, 300);
        });
    </script>
}